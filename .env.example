# ============================================================================
# Agno API - Docker Configuration
# ============================================================================
# IMPORTANTE: Preencher ANTHROPIC_API_KEY com sua chave Anthropic

# ============================================================================
# REQUIRED - Preencher com sua chave Anthropic
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-...sua_chave_aqui...

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
POSTGRES_USER=agno_user
POSTGRES_PASSWORD=agno_password
POSTGRES_DB=agno_memory
POSTGRES_PORT=5432

# ============================================================================
# LLM Configuration
# ============================================================================
LLM_MODEL_ID=claude-haiku-4-5-20251001
LLM_REQUEST_TIMEOUT=30

# ============================================================================
# Learning Machine Configuration
# ============================================================================
LEARNING_MODE=always
ENABLE_ENTITY_MEMORY=true

# ============================================================================
# Recall Parameters
# ============================================================================
RECALL_MAX_TOKENS=300
RECALL_MIN_RELEVANCE_DAYS=30

# ============================================================================
# Request Validation
# ============================================================================
MAX_MESSAGES_PER_REQUEST=100
MAX_MESSAGE_LENGTH=10000
MAX_SESSION_ID_LENGTH=255

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_PROFILING=false
ENABLE_METRICS=true
